{
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/angular/(.*)", "destination": "/angular/index.html" },
    { "source": "/preact/(.*)", "destination": "/preact/index.html" },
    { "source": "/react/(.*)", "destination": "/react/index.html" },
    { "source": "/solid/(.*)", "destination": "/solid/index.html" },
    { "source": "/svelte/(.*)", "destination": "/svelte/index.html" },
    { "source": "/vue/(.*)", "destination": "/vue/index.html" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}